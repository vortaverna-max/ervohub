local function getSidePositions()
    if not detectedSide then return nil, nil, nil, nil end
    if detectedSide == "L" then
        return POSITION_1, POSITION_2, POSITION_R1, POSITION_R2
    else
        return POSITION_R1, POSITION_R2, POSITION_1, POSITION_2
    end
end

local function runSideDetection()
    local c = Player.Character; if not c then return end
    local h = c:FindFirstChild("HumanoidRootPart"); if not h then return end
    local dL = (Vector3.new(POSITION_1.X, 0, POSITION_1.Z) - Vector3.new(h.Position.X, 0, h.Position.Z)).Magnitude
    local dR = (Vector3.new(POSITION_R1.X, 0, POSITION_R1.Z) - Vector3.new(h.Position.X, 0, h.Position.Z)).Magnitude
    detectedSide = (dL < dR) and "R" or "L"
    return detectedSide
end

