local function createSlider(parent, yPos, labelText, valueKey, minVal, maxVal, isDecimal)
    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(1,-10,0,44); row.Position = UDim2.new(0,5,0,yPos)
    row.BackgroundTransparency = 1; row.ZIndex = 3
    local label = Instance.new("TextLabel", row)
    label.Size = UDim2.new(0.52,0,0.5,0); label.Position = UDim2.new(0,10,0,0)
    label.BackgroundTransparency = 1; label.Text = labelText
    label.TextColor3 = C.textDim; label.Font = FONT; label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left; label.ZIndex = 4
    local valLbl = Instance.new("TextLabel", row)
    valLbl.Size = UDim2.new(0.45,0,0.5,0); valLbl.Position = UDim2.new(0.52,0,0,0)
    valLbl.BackgroundTransparency = 1
    local curVal = Values[valueKey]
    valLbl.Text = isDecimal and string.format("%.1f",curVal) or tostring(math.floor(curVal))
    valLbl.TextColor3 = C.lightGray; valLbl.Font = FONT; valLbl.TextSize = 12
    valLbl.TextXAlignment = Enum.TextXAlignment.Right; valLbl.ZIndex = 4
    local track = Instance.new("Frame", row)
    track.Size = UDim2.new(1,-20,0,8); track.Position = UDim2.new(0,10,1,-16)
    track.BackgroundColor3 = C.darkGray; track.ZIndex = 4
    Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)
    local pct = math.clamp((curVal-minVal)/(maxVal-minVal), 0, 1)
    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new(pct,0,1,0); fill.BackgroundColor3 = C.white; fill.ZIndex = 5
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)
    local thumb = Instance.new("Frame", track)
    thumb.Size = UDim2.new(0,14,0,14); thumb.Position = UDim2.new(pct,-7,0.5,-7)
    thumb.BackgroundColor3 = C.white; thumb.ZIndex = 6
    Instance.new("UICorner", thumb).CornerRadius = UDim.new(1,0)
    local hitbox = Instance.new("TextButton", track)
    hitbox.Size = UDim2.new(1,0,4,0); hitbox.Position = UDim2.new(0,0,-1.5,0)
    hitbox.BackgroundTransparency = 1; hitbox.Text = ""; hitbox.ZIndex = 7
    local dragging = false
    local function updateVal(rel)
        rel = math.clamp(rel, 0, 1)
        fill.Size = UDim2.new(rel,0,1,0); thumb.Position = UDim2.new(rel,-7,0.5,-7)
        local v = minVal + (maxVal-minVal)*rel
        local snapped = isDecimal and (math.floor(v*10+0.5)/10) or math.floor(v+0.5)
        Values[valueKey] = snapped
        valLbl.Text = isDecimal and string.format("%.1f",snapped) or tostring(snapped)
    end
    hitbox.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            updateVal((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X)
        end
    end)
    return row, function(v) updateVal(math.clamp((v-minVal)/(maxVal-minVal),0,1)) end
end

