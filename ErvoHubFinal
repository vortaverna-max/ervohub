           st == Enum.HumanoidStateType.FallingDown or
           st == Enum.HumanoidStateType.Physics then
            stopAutoPlayLeft()
            Enabled.AutoPlaySide = false
            if VisualSetters.AutoPlaySide then VisualSetters.AutoPlaySide(false) end
        end
    end)
    autoPlayLeftConn = RunService.Heartbeat:Connect(function()
        if not Enabled.AutoPlayLeft or not aplRunning then stopAutoPlayLeft(); return end
        local c = Player.Character; if not c then return end
