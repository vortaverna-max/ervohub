    Enabled.AutoPlayLeft = false
    aplRunning = false
    if aplRagdollConn then aplRagdollConn:Disconnect(); aplRagdollConn = nil end
    if autoPlayLeftConn then autoPlayLeftConn:Disconnect(); autoPlayLeftConn = nil end
    local c = Player.Character
    if c then
        local h = c:FindFirstChild("HumanoidRootPart")
        if h then h.AssemblyLinearVelocity = Vector3.new(0, h.AssemblyLinearVelocity.Y, 0) end
    end
end

