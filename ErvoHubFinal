-- ═══════════════════════════════════════════════════
-- TOUCH VOID
-- Instantly CFrame-teleports touched players to Y=-5000
-- (below the map void) and keeps pushing them down
-- for 1 second so server corrections can't save them.
-- CFrame is the only truly reliable client-side method
-- since we own the touch event and can set position.
-- ═══════════════════════════════════════════════════
local touchVoidConns = {}
local touchVoidCooldowns = {}
local touchVoidActiveTargets = {} -- track who is being voided

local function voidFling(hitChar)
    local hitPlayer = Players:GetPlayerFromCharacter(hitChar)
    if not hitPlayer or hitPlayer == Player then return end
    local now = tick()
    if touchVoidCooldowns[hitPlayer] and now - touchVoidCooldowns[hitPlayer] < 3 then return end
    touchVoidCooldowns[hitPlayer] = now
    if touchVoidActiveTargets[hitPlayer] then return end
    touchVoidActiveTargets[hitPlayer] = true

    task.spawn(function()
        local char = hitPlayer.Character
        if not char then touchVoidActiveTargets[hitPlayer] = nil; return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then touchVoidActiveTargets[hitPlayer] = nil; return end

        -- Teleport high above the map (10000 studs up) so they fall
        -- and the fall distance / void zone kills them naturally.
        -- Re-apply 3 times over 0.15s so server corrections don't snap them back.
        local VOID_Y = 10000
        local currentX = hrp.Position.X
        local currentZ = hrp.Position.Z

        for _ = 1, 3 do
            pcall(function()
                hrp.CFrame = CFrame.new(currentX, VOID_Y, currentZ)
                hrp.AssemblyLinearVelocity  = Vector3.new(0, 0, 0)
                hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            end)
            task.wait(0.05)
        end

        touchVoidActiveTargets[hitPlayer] = nil
    end)
end

local function setupTouchVoid()
    for _, conn in pairs(touchVoidConns) do
        if conn then conn:Disconnect() end
    end
    touchVoidConns = {}
    touchVoidCooldowns = {}
    if not Enabled.TouchVoid then return end
    local c = Player.Character; if not c then return end
    for _, part in ipairs(c:GetDescendants()) do
        if part:IsA("BasePart") then
            local conn = part.Touched:Connect(function(hit)
                if not Enabled.TouchVoid then return end
                voidFling(hit.Parent)
            end)
            table.insert(touchVoidConns, conn)
        end
    end
end

local function startTouchVoid()
    setupTouchVoid()
end

local function stopTouchVoid()
    for _, conn in pairs(touchVoidConns) do
        if conn then conn:Disconnect() end
    end
    touchVoidConns = {}
    touchVoidCooldowns = {}
    touchVoidActiveTargets = {}
end

-- ═══════════════════════════════════════════════════
-- BAT AIMBOT
-- ═══════════════════════════════════════════════════
local function findNearestEnemy(myHRP)
    local nearest, nearestDist, nearestTorso = nil, math.huge, nil
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Player and p.Character then
            local eh    = p.Character:FindFirstChild("HumanoidRootPart")
            local torso = p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso")
            local hum   = p.Character:FindFirstChildOfClass("Humanoid")
            if eh and hum and hum.Health > 0 then
                local d = (eh.Position - myHRP.Position).Magnitude
                if d < nearestDist then nearestDist=d; nearest=eh; nearestTorso=torso or eh end
            end
        end
    end
    return nearest, nearestDist, nearestTorso
end

local function startBatAimbot()
    if Connections.batAimbot then return end
    Connections.batAimbot = RunService.Heartbeat:Connect(function(dt)
        if not Enabled.BatAimbot then return end
        local c = Player.Character; if not c then return end
        local h = c:FindFirstChild("HumanoidRootPart")
        local hum = c:FindFirstChildOfClass("Humanoid")
        if not h or not hum then return end
        local bat = findBat()
        if bat and bat.Parent ~= c then hum:EquipTool(bat) end
        local target, dist, torso = findNearestEnemy(h)
        aimbotTarget = torso or target
        if target and torso then
            pcall(function() hum.PlatformStand = true end)
            local dir = (torso.Position - h.Position)
            local dist2 = dir.Magnitude
            local spd = Values.BatAimbotSpeed
            if dist2 > 0.01 then
                local moveDir = dir.Unit
                h.AssemblyLinearVelocity = Vector3.new(moveDir.X*spd, moveDir.Y*spd, moveDir.Z*spd)
            else
                local tv = target.AssemblyLinearVelocity
                h.AssemblyLinearVelocity = tv
            end
        else
            pcall(function() hum.PlatformStand = false end)
        end
    end)
end

local function stopBatAimbot()
    if Connections.batAimbot then Connections.batAimbot:Disconnect() Connections.batAimbot = nil end
    aimbotTarget = nil
    pcall(function()
        local c = Player.Character; if not c then return end
        local hum = c:FindFirstChildOfClass("Humanoid"); if not hum then return end
        hum.PlatformStand = false
    end)
end

