-- ═══════════════════════════════════════════════════
-- FPS BOOST / OPTIMIZER
-- Fixed: BillboardGui text labels are preserved
-- ═══════════════════════════════════════════════════
local optimizerDescConn    = nil
local optimizerCharConn    = nil
local optimizerCharDescConn= nil
local savedOptimizerLight  = {}

local LASER_KEYWORDS = {"laser","door","gate","barrier","kill","damage","neon","force","wall"}
local OPT_NUKE_CLASSES = {
    ParticleEmitter=true, Trail=true, Beam=true,
    Smoke=true, Fire=true, Sparkles=true,
    BloomEffect=true, BlurEffect=true, SunRaysEffect=true,
    DepthOfFieldEffect=true, ColorCorrectionEffect=true, Atmosphere=true,
    SelectionBox=true, SelectionSphere=true,
    -- BillboardGui and SurfaceGui are intentionally NOT in this list anymore
    -- so that text labels (nametags, ESP, overhead labels) remain visible
    Decal=true, Texture=true,
    PointLight=true, SpotLight=true, SurfaceLight=true,
}
local OPT_APPEARANCE_CLASSES = {
    Shirt=true, Pants=true, ShirtGraphic=true,
    Accessory=true, Hat=true, CharacterMesh=true, BodyColors=true,
}

-- BillboardGui/SurfaceGui that are purely cosmetic (no TextLabel children) can be nuked.
-- But any that contain TextLabel or ImageLabel children are kept so text stays visible.
local function optShouldNukeGui(obj)
    if not (obj:IsA("BillboardGui") or obj:IsA("SurfaceGui")) then return false end
    -- Keep any GUI that has text labels (nametags, ESP overlays, indicators)
    for _, child in ipairs(obj:GetDescendants()) do
        if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("ImageLabel") then
            return false
        end
    end
    return true
end

local function optIsLaserPart(obj)
    local name = obj.Name:lower()
    for _, kw in ipairs(LASER_KEYWORDS) do if name:find(kw) then return true end end
    if obj.Material == Enum.Material.Neon then return true end
    if obj.Transparency > 0.5 then return true end
    return false
end

local function optNukeObj(obj)
    pcall(function()
        if Player.Character and obj:IsDescendantOf(Player.Character) then return end
        -- Preserve BillboardGui/SurfaceGui that contain text (nametags etc.)
        if obj:IsA("BillboardGui") or obj:IsA("SurfaceGui") then
            if optShouldNukeGui(obj) then obj:Destroy() end
            return
        end
        local plots = workspace:FindFirstChild("Plots")
        if plots and obj:IsDescendantOf(plots) then
            if obj:IsA("BillboardGui") or obj:IsA("SurfaceGui") then return end
        end
        if OPT_NUKE_CLASSES[obj.ClassName] then obj:Destroy(); return end
        if OPT_APPEARANCE_CLASSES[obj.ClassName] then obj:Destroy(); return end
        if obj:IsA("BasePart") and not obj:IsA("Terrain") and not optIsLaserPart(obj) then
            obj.CastShadow  = false
