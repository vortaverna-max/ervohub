    aplRunning = true
    local phases = {POSITION_1, POSITION_2, POSITION_1, POSITION_R1, POSITION_R2}
    local orbPhases = {[2]=true, [5]=true}
    local phase = 1
    local useCarry = false  -- flips to true at orb phases
    aplRagdollConn = RunService.Heartbeat:Connect(function()
        if not Enabled.AutoPlayLeft then
            aplRagdollConn:Disconnect(); aplRagdollConn = nil; return
