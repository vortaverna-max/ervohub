local function applySpeed(h, spd, moveDir)
    h.AssemblyLinearVelocity = Vector3.new(
        moveDir.X * spd,
        h.AssemblyLinearVelocity.Y,
        moveDir.Z * spd
    )
end

local function startSpeedBoost()
    if Connections.speed then return end
    local _t = 0
    Connections.speed = RunService.Heartbeat:Connect(function(dt)
        if not Enabled.SpeedBoost then return end
        if AutoWalkEnabled or AutoRightEnabled or Enabled.BatAimbot then return end
        _t = _t + dt; if _t < 0.016 then return end; _t = 0
        pcall(function()
            local c = Player.Character; if not c then return end
            local h = c:FindFirstChild("HumanoidRootPart"); if not h then return end
            local md = getMovementDirection()
            if md.Magnitude > 0.1 then
                applySpeed(h, Values.SpeedBoostValue, md)
            end
        end)
    end)
end

local function stopSpeedBoost()
    if Connections.speed then Connections.speed:Disconnect() Connections.speed = nil end
end

local function startBooster()
    if not Connections.boosterSpeed then
        Connections.boosterSpeed = RunService.Heartbeat:Connect(function()
            if not Enabled.Booster then return end
            if AutoWalkEnabled or AutoRightEnabled or Enabled.BatAimbot then return end
            pcall(function()
                local c = Player.Character; if not c then return end
                local h = c:FindFirstChild("HumanoidRootPart"); if not h then return end
                local md = getMovementDirection()
                if md.Magnitude > 0.1 then
                    applySpeed(h, Values.BoosterSpeed, md)
                end
            end)
        end)
    end
end

local function stopBooster()
    if Connections.boosterSpeed then Connections.boosterSpeed:Disconnect() Connections.boosterSpeed = nil end
end

