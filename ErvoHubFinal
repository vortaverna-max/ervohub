-- ═══════════════════════════════════════════════════
-- AUTO BRAINROT RETURN
-- ═══════════════════════════════════════════════════
local abrReturnConn = nil
local abrMoveConn   = nil
local abrRunning    = false
local abrWasRagdoll = false

local function stopAutoBrainrotReturn()
    Enabled.AutoBrainrotReturn = false
    abrRunning    = false
    abrWasRagdoll = false
    if abrReturnConn then abrReturnConn:Disconnect(); abrReturnConn = nil end
    if abrMoveConn   then abrMoveConn:Disconnect();   abrMoveConn   = nil end
    local c = Player.Character
    if c then
        local h = c:FindFirstChild("HumanoidRootPart")
        if h then h.AssemblyLinearVelocity = Vector3.new(0, h.AssemblyLinearVelocity.Y, 0) end
    end
end
local function stopAutoBrainrotReturnL() stopAutoBrainrotReturn() end
local function stopAutoBrainrotReturnR() stopAutoBrainrotReturn() end

local function startAutoBrainrotReturn()
    if abrReturnConn then abrReturnConn:Disconnect(); abrReturnConn = nil end
    if abrMoveConn   then abrMoveConn:Disconnect();   abrMoveConn   = nil end
    abrRunning    = false
    abrWasRagdoll = false
    Enabled.AutoBrainrotReturn = true

    local function hookHumanoid()
        local c = Player.Character; if not c then return end
        local hum = c:FindFirstChildOfClass("Humanoid"); if not hum then return end

        if abrReturnConn then abrReturnConn:Disconnect(); abrReturnConn = nil end

        abrReturnConn = hum.StateChanged:Connect(function(_, new)
            if not Enabled.AutoBrainrotReturn then return end
            if abrRunning then return end
            if new ~= Enum.HumanoidStateType.Ragdoll and
               new ~= Enum.HumanoidStateType.FallingDown and
               new ~= Enum.HumanoidStateType.Physics then return end

            abrRunning = true

            local side   = detectedSide
            local startP, route
            if side == "L" then
                startP = POSITION_1
                route  = {POSITION_2, POSITION_1, POSITION_R1, POSITION_R2}
            else
                startP = POSITION_R1
                route  = {POSITION_R2, POSITION_R1, POSITION_1, POSITION_2}
            end

            task.spawn(function()
                task.wait(0.1)
                if not Enabled.AutoBrainrotReturn then abrRunning = false; return end

                local c2 = Player.Character; if not c2 then abrRunning = false; return end
                local h2 = c2:FindFirstChild("HumanoidRootPart"); if not h2 then abrRunning = false; return end

                h2.CFrame = CFrame.new(startP.X, h2.Position.Y, startP.Z)
                h2.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                task.wait(0.05)
                if not Enabled.AutoBrainrotReturn then abrRunning = false; return end

                local SPEED   = Values.AutoBRLSpeed
                local TIMEOUT = 15
                local phase   = 1
                local startT  = tick()

                if abrMoveConn then abrMoveConn:Disconnect(); abrMoveConn = nil end
                abrMoveConn = RunService.Heartbeat:Connect(function()
                    if not Enabled.AutoBrainrotReturn then
                        abrMoveConn:Disconnect(); abrMoveConn = nil; abrRunning = false; return
                    end
                    if tick() - startT > TIMEOUT then
                        abrMoveConn:Disconnect(); abrMoveConn = nil; abrRunning = false; return
                    end
                    local c3 = Player.Character; if not c3 then abrMoveConn:Disconnect(); abrMoveConn = nil; abrRunning = false; return end
                    local h3 = c3:FindFirstChild("HumanoidRootPart"); if not h3 then abrMoveConn:Disconnect(); abrMoveConn = nil; abrRunning = false; return end
                    if getMovementDirection().Magnitude > 0.1 then
                        h3.AssemblyLinearVelocity = Vector3.new(0, h3.AssemblyLinearVelocity.Y, 0)
                        abrMoveConn:Disconnect(); abrMoveConn = nil; abrRunning = false; return
                    end
                    SPEED = Values.AutoBRLSpeed -- live-read so slider changes take effect
                    if phase > #route then
                        h3.AssemblyLinearVelocity = Vector3.new(0, h3.AssemblyLinearVelocity.Y, 0)
                        abrMoveConn:Disconnect(); abrMoveConn = nil; abrRunning = false; return
                    end
                    local tgt  = route[phase]
                    local dx   = tgt.X - h3.Position.X
                    local dz   = tgt.Z - h3.Position.Z
                    local dist = math.sqrt(dx*dx + dz*dz)
                    if dist < 2 then
                        h3.AssemblyLinearVelocity = Vector3.new(0, h3.AssemblyLinearVelocity.Y, 0)
                        phase = phase + 1
                    else
                        local dir = Vector3.new(dx/dist, 0, dz/dist)
                        applySpeed(h3, SPEED, dir)
                    end
                end)
            end)
        end)
    end

    hookHumanoid()
end
local function startAutoBrainrotReturnL() startAutoBrainrotReturn() end
local function startAutoBrainrotReturnR() startAutoBrainrotReturn() end

Player.CharacterAdded:Connect(function()
    task.wait(1)
    abrRunning    = false
    abrWasRagdoll = false
    if Enabled.AutoBrainrotReturn then startAutoBrainrotReturn() end
end)

