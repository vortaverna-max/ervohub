local function toggleGui(vis)
    if not loadingDone then return end
    guiVisible = vis
    if vis then
        ervoBtn.Visible = false
        main.Visible = true
    else
        main.Visible = false
    end
end

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if waitingForKeybind and input.KeyCode ~= Enum.KeyCode.Unknown then
        local k = input.KeyCode
        KEYBINDS[waitingForKeybind] = k
        if KeyButtons[waitingForKeybind] then
            KeyButtons[waitingForKeybind].Text = k.Name
            KeyButtons[waitingForKeybind].TextColor3 = C.lightGray
        end
        waitingForKeybind = nil; return
    end
    if input.KeyCode == Enum.KeyCode.U then toggleGui(not guiVisible); return end
    if input.KeyCode == Enum.KeyCode.Space then
        if not spaceDown then spaceHeld = true end; spaceDown = true; return
    end
    local kbMap = {
        SPEEDMODE    = function() applySpeedMode(not speedMode) end,
        DROPBRAINROT = function() if doDrop then doDrop() end end,
        AUTOLEFT     = function()
            local s = not Enabled.AutoSide; Enabled.AutoSide = s
            if VisualSetters.AutoSide then VisualSetters.AutoSide(s) end
            if s then
                if detectedSide == "L" then AutoWalkEnabled=true; Enabled.AutoWalkEnabled=true; startAutoWalk()
                elseif detectedSide == "R" then AutoRightEnabled=true; Enabled.AutoRightEnabled=true; startAutoRight() end
            else
                AutoWalkEnabled=false; Enabled.AutoWalkEnabled=false; stopAutoWalk()
                AutoRightEnabled=false; Enabled.AutoRightEnabled=false; stopAutoRight()
            end
        end,
        AUTOPLAYSIDE = function()
            local s = not Enabled.AutoPlaySide; Enabled.AutoPlaySide = s
            if VisualSetters.AutoPlaySide then VisualSetters.AutoPlaySide(s) end
            if s then
                if detectedSide == "L" then startAutoPlayLeft()
                elseif detectedSide == "R" then startAutoPlayRight() end
            else
                stopAutoPlayLeft(); stopAutoPlayRight()
            end
        end,
        AUTOSTEAL    = function()
            local s = not Enabled.AutoSteal; Enabled.AutoSteal = s
            if VisualSetters.AutoSteal then VisualSetters.AutoSteal(s) end
            if s then startAutoSteal() else stopAutoSteal() end
        end,
        BATAIMBOT    = function()
            local s = not Enabled.BatAimbot; Enabled.BatAimbot = s
            if VisualSetters.BatAimbot then VisualSetters.BatAimbot(s) end
            if s then startBatAimbot() else stopBatAimbot() end
        end,
        GALAXY       = function()
            local s = not Enabled.Galaxy; Enabled.Galaxy = s
            if VisualSetters.Galaxy then VisualSetters.Galaxy(s) end
            if s then startGalaxy() else stopGalaxy() end
        end,
        FLOAT        = function()
            local s = not Enabled.Float; Enabled.Float = s
            if VisualSetters.Float then VisualSetters.Float(s) end
            if s then startFloat() else stopFloat() end
        end,
    }
    for key, fn in pairs(kbMap) do
        if KEYBINDS[key] and input.KeyCode == KEYBINDS[key] then fn(); return end
    end
end)

