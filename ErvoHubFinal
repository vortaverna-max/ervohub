local autoPlayLeftConn  = nil
local autoPlayRightConn = nil
local aplRunning = false
local aprRunning = false

local function driveToward(h, target, spd)
    local dx = target.X - h.Position.X
    local dz = target.Z - h.Position.Z
    local dist = math.sqrt(dx*dx + dz*dz)
    if dist < 2 then
        h.AssemblyLinearVelocity = Vector3.new(0, h.AssemblyLinearVelocity.Y, 0)
        return true
    end
    local dir = Vector3.new(dx/dist, 0, dz/dist)
    applySpeed(h, spd, dir)
    return false
end

