    })

    -- ── BUTTON BUILDER ──
    local BTN_W, BTN_H = 140, 150
    local BTN_Y = 76
    local function btnX(idx) return 12 + (idx-1)*(BTN_W+6) end

    local function makeBtn(idx, version, icon, title, subtitle, badgeText, badgeColor, imageSrc)
        local btn = Instance.new("Frame", card)
        btn.Size = UDim2.new(0,BTN_W,0,BTN_H)
        btn.Position = UDim2.new(0,btnX(idx),0,BTN_Y)
        btn.BackgroundColor3 = Color3.fromRGB(10,10,10)
        btn.BorderSizePixel = 0; btn.ZIndex = 53; btn.ClipsDescendants = true
        btn.BackgroundTransparency = 1
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0,12)

        task.delay(idx*0.1, function()
            TweenService:Create(btn, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {BackgroundTransparency=0}):Play()
        end)

        -- Dragon image — smaller & centered so it doesn't stretch
        -- ScaleType.Fit preserves aspect ratio; 0.72 scale = ~100px wide inside 140px button
        local bgImage = nil
        if imageSrc then
            bgImage = Instance.new("ImageLabel", btn)
            bgImage.Size                 = UDim2.new(0.72, 0, 0.72, 0)
            bgImage.Position             = UDim2.new(0.14, 0, 0.07, 0)   -- centered horizontally, slight top offset
            bgImage.BackgroundTransparency = 1
            bgImage.Image                = imageSrc
            bgImage.ImageTransparency    = 0.45   -- 10% more transparent than before
            bgImage.ScaleType            = Enum.ScaleType.Fit   -- NEVER stretches, keeps aspect ratio
            bgImage.ZIndex               = 54
        end

        -- Animated stroke
        local bStroke = Instance.new("UIStroke", btn); bStroke.Thickness = 1.2; bStroke.Transparency = 0.5
        local bGrad = Instance.new("UIGradient", bStroke)
        local offIdle = ColorSequence.new({
            ColorSequenceKeypoint.new(0,   Color3.fromRGB(65,65,65)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(28,28,28)),
            ColorSequenceKeypoint.new(1,   Color3.fromRGB(65,65,65))
        })
        local onHover = ColorSequence.new({
            ColorSequenceKeypoint.new(0,   Color3.fromRGB(210,210,210)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(90,90,90)),
            ColorSequenceKeypoint.new(1,   Color3.fromRGB(210,210,210))
        })
        bGrad.Color = offIdle
        local bOff = (idx==1) and 30 or (idx==2 and 210 or 120)
        task.spawn(function()
            local r = bOff
            while btn.Parent do r=(r+3)%360; bGrad.Rotation=r; task.wait(0.02) end
        end)

        -- Mini particles (ZIndex 55 — above image)
        local mrng = Random.new(idx*11)
        for _mi = 1, 8 do
            local md = Instance.new("Frame", btn)
            md.Size = UDim2.new(0,mrng:NextInteger(1,3),0,mrng:NextInteger(1,3))
            local msx = mrng:NextNumber(0.05,0.95); local msy = mrng:NextNumber(0.05,0.95)
            md.Position = UDim2.new(msx,0,msy,0)
            md.BackgroundColor3 = Color3.fromRGB(110,110,110)
            md.BackgroundTransparency = mrng:NextNumber(0.4,0.7)
            md.BorderSizePixel = 0; md.ZIndex = 55
            Instance.new("UICorner",md).CornerRadius = UDim.new(1,0)
            local mph = mrng:NextNumber()*math.pi*2; local msm = 0.18+mrng:NextNumber()*0.28
            local msxf, msyf = msx, msy
            task.spawn(function()
                while md.Parent do
                    local t = tick()+mph
                    md.Position = UDim2.new(math.clamp(msxf+math.sin(t*msm)*0.04,0.02,0.98),0,math.clamp(msyf+math.cos(t*msm*0.8)*0.05,0.02,0.98),0)
                    md.BackgroundTransparency = 0.4+math.sin(t*1.6+mph)*0.3
                    task.wait(0.04)
                end
            end)
        end

        -- Top accent bar
        local accentBar = Instance.new("Frame", btn)
        accentBar.Size = UDim2.new(1,0,0,2); accentBar.BackgroundColor3 = Color3.fromRGB(55,55,55)
        accentBar.BorderSizePixel = 0; accentBar.ZIndex = 56
        Instance.new("UIGradient", accentBar).Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,   Color3.fromRGB(0,0,0)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(140,140,140)),
            ColorSequenceKeypoint.new(1,   Color3.fromRGB(0,0,0))
        })

        -- Icon symbol — skipped for dragon button (no circle symbol)
        local iconLbl = nil
        if icon ~= "" then
            iconLbl = Instance.new("TextLabel", btn)
            iconLbl.Size = UDim2.new(1,0,0,38); iconLbl.Position = UDim2.new(0,0,0,10)
            iconLbl.BackgroundTransparency = 1; iconLbl.Text = icon
            iconLbl.Font = Enum.Font.GothamBlack; iconLbl.TextSize = 28
            iconLbl.TextColor3 = Color3.fromRGB(200,200,200); iconLbl.ZIndex = 57
            iconLbl.TextXAlignment = Enum.TextXAlignment.Center
        end

        -- Badge pill
        -- Dragon button: badge moves to the BOTTOM of the button
        local badgeY = imageSrc and (BTN_H - 22) or 52
        local badgePill = Instance.new("Frame", btn)
        badgePill.Size = UDim2.new(0,32,0,15); badgePill.Position = UDim2.new(0.5,-16,0,badgeY)
        badgePill.BackgroundColor3 = Color3.fromRGB(18,18,18); badgePill.BorderSizePixel = 0; badgePill.ZIndex = 57
        Instance.new("UICorner", badgePill).CornerRadius = UDim.new(0,6)
        local bpStroke = Instance.new("UIStroke", badgePill); bpStroke.Thickness = 1; bpStroke.Color = badgeColor
        local badgeLbl = Instance.new("TextLabel", badgePill)
        badgeLbl.Size = UDim2.new(1,0,1,0); badgeLbl.BackgroundTransparency = 1
        badgeLbl.Text = badgeText; badgeLbl.Font = Enum.Font.GothamBlack; badgeLbl.TextSize = 9
        badgeLbl.TextColor3 = badgeColor; badgeLbl.ZIndex = 58

        -- Title — dragon button: "Dragon\nDuper" in two stacked lines, GothamBlack
        -- Other buttons: single-line title as before
        local titleText = title
        local titleH    = imageSrc and 44 or 22
        local titleY    = imageSrc and 54  or 72
        local vTitle = Instance.new("TextLabel", btn)
        vTitle.Size = UDim2.new(1,-8,0,titleH); vTitle.Position = UDim2.new(0,4,0,titleY)
        vTitle.BackgroundTransparency = 1; vTitle.Text = titleText
        vTitle.Font = Enum.Font.GothamBlack
        vTitle.TextSize = imageSrc and 16 or 14
        vTitle.TextColor3 = Color3.fromRGB(235,235,235); vTitle.ZIndex = 57
        vTitle.TextXAlignment = Enum.TextXAlignment.Center
        vTitle.TextWrapped = true; vTitle.LineHeight = 1.1

        -- Subtitle
        local subY = imageSrc and (titleY + titleH + 2) or 96
        local vSub = Instance.new("TextLabel", btn)
        vSub.Size = UDim2.new(1,-8,0,28); vSub.Position = UDim2.new(0,4,0,subY)
        vSub.BackgroundTransparency = 1; vSub.Text = subtitle
        vSub.Font = Enum.Font.GothamBold   -- bold on all buttons
        vSub.TextSize = 9
        vSub.TextColor3 = Color3.fromRGB(90,90,90); vSub.ZIndex = 57
        vSub.TextXAlignment = Enum.TextXAlignment.Center; vSub.TextWrapped = true

        -- Dragon button: no stroke, colours match other buttons

        -- Click overlay
        local clickOver = Instance.new("TextButton", btn)
        clickOver.Size = UDim2.new(1,0,1,0); clickOver.BackgroundTransparency = 1
        clickOver.Text = ""; clickOver.ZIndex = 59; clickOver.AutoButtonColor = false

        clickOver.MouseEnter:Connect(function()
            TweenService:Create(btn,       TweenInfo.new(0.15), {BackgroundColor3=Color3.fromRGB(20,20,20)}):Play()
            TweenService:Create(bStroke,   TweenInfo.new(0.15), {Transparency=0}):Play()
            if iconLbl then TweenService:Create(iconLbl, TweenInfo.new(0.15), {TextColor3=Color3.fromRGB(255,255,255)}):Play() end
            TweenService:Create(accentBar, TweenInfo.new(0.15), {BackgroundColor3=Color3.fromRGB(130,130,130)}):Play()
            if bgImage then TweenService:Create(bgImage, TweenInfo.new(0.15), {ImageTransparency=0.25}):Play() end
            bGrad.Color = onHover
        end)
        clickOver.MouseLeave:Connect(function()
            TweenService:Create(btn,       TweenInfo.new(0.15), {BackgroundColor3=Color3.fromRGB(10,10,10)}):Play()
            TweenService:Create(bStroke,   TweenInfo.new(0.15), {Transparency=0.5}):Play()
            if iconLbl then TweenService:Create(iconLbl, TweenInfo.new(0.15), {TextColor3=Color3.fromRGB(200,200,200)}):Play() end
            TweenService:Create(accentBar, TweenInfo.new(0.15), {BackgroundColor3=Color3.fromRGB(55,55,55)}):Play()
            if bgImage then TweenService:Create(bgImage, TweenInfo.new(0.15), {ImageTransparency=0.45}):Play() end
            bGrad.Color = offIdle
        end)

        return clickOver, btn
    end

    local v1Click, v1Btn = makeBtn(
        1, "v1", "◈", "Duels",
        "Optimised for PC\nBest performance",
        "V1", Color3.fromRGB(160,160,160),
        nil
