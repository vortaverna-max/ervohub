        "Unpatched Dragon Duper",
        "V3", Color3.fromRGB(180,180,180),
        DRAGON_IMG
    )

    -- Footer
    local footerLbl = Instance.new("TextLabel", card)
    footerLbl.Size = UDim2.new(1,0,0,18); footerLbl.Position = UDim2.new(0,0,1,-22)
    footerLbl.BackgroundTransparency = 1; footerLbl.Text = "tap a version to launch  ·  ervo hub"
    footerLbl.Font = Enum.Font.Gotham; footerLbl.TextSize = 9
    footerLbl.TextColor3 = Color3.fromRGB(38,38,38); footerLbl.ZIndex = 55; footerLbl.TextTransparency = 1
    footerLbl.TextXAlignment = Enum.TextXAlignment.Center
    TweenService:Create(footerLbl, TweenInfo.new(0.7), {TextTransparency=0}):Play()

    -- ── ON SELECT ──
    local function onVersionSelected(version, selectedBtn)
        selPulseActive = false

        TweenService:Create(selectedBtn, TweenInfo.new(0.1), {BackgroundColor3=Color3.fromRGB(255,255,255)}):Play()
        task.wait(0.1)
        TweenService:Create(selectedBtn, TweenInfo.new(0.1), {BackgroundColor3=Color3.fromRGB(30,30,30)}):Play()
        task.wait(0.15)

        TweenService:Create(card, TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.In),
            {BackgroundTransparency=1, Position=UDim2.new(0.5,-CARD_W/2,0.4,-CARD_H/2)}):Play()
        TweenService:Create(selDim, TweenInfo.new(0.5), {BackgroundTransparency=1}):Play()
        for _, obj in ipairs(card:GetDescendants()) do
            if obj:IsA("TextLabel")  then TweenService:Create(obj, TweenInfo.new(0.3), {TextTransparency=1}):Play() end
            if obj:IsA("Frame")      then TweenService:Create(obj, TweenInfo.new(0.3), {BackgroundTransparency=1}):Play() end
            if obj:IsA("UIStroke")   then TweenService:Create(obj, TweenInfo.new(0.3), {Transparency=1}):Play() end
            if obj:IsA("ImageLabel") then TweenService:Create(obj, TweenInfo.new(0.3), {ImageTransparency=1}):Play() end
        end

        task.wait(0.6)
        card:Destroy(); selDim:Destroy(); sg:Destroy()

        if version == "v1" then
            loadstring(game:HttpGet("https://raw.githubusercontent.com/vortaverna-max/ervohub/refs/heads/main/Chasm.txt"))()
        elseif version == "v2" then
            loadstring(game:HttpGet("https://raw.githubusercontent.com/vortaverna-max/ervohub/refs/heads/main/Jasmine.txt"))()
        elseif version == "dupe" then
            -- Dupe
            loadstring(game:HttpGet("https://raw.githubusercontent.com/vortaverna-max/ervohub/refs/heads/main/Socrates.txt"))()
        end
    end

    v1Click.MouseButton1Click:Connect(function() onVersionSelected("v1", v1Btn) end)
    v2Click.MouseButton1Click:Connect(function() onVersionSelected("v2", v2Btn) end)
    dupeClick.MouseButton1Click:Connect(function() onVersionSelected("dupe", dupBtn) end)
end)
