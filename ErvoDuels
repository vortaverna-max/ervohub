task.spawn(function()
    local steps = {"Initializing...","Loading modules...","Building interface...","Almost there...","Launching!"}
    local elapsed = 0
    local stepInterval = LOAD_DURATION / #steps
    local nextStep = stepInterval; local si = 1
    while elapsed < LOAD_DURATION and ls.Parent do
        elapsed = elapsed + 0.05
        local pct = math.min(elapsed / LOAD_DURATION, 1)
        TweenService:Create(pFillLs, TweenInfo.new(0.05), {Size = UDim2.new(pct,0,1,0)}):Play()
        pctLbl.Text = math.floor(pct*100) .. "%"
        if elapsed >= nextStep and si <= #steps then
            lSub.Text = steps[si]; si = si+1; nextStep = nextStep + stepInterval
        end
        task.wait(0.05)
    end
end)

